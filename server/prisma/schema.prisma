generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String            @id @default(uuid())
  email                String?           @unique
  password             String
  name                 String?
  avatar               String?
  role                 String            @default("USER")
  isBlocked            Boolean           @default(false)
  addresses            String            @default("[]")
  isPhoneVerified      Boolean           @default(false)
  isWishlistPublic     Boolean           @default(true)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  storeName            String?
  storeDescription     String?
  storeLogo            String?
  storeBanner          String?
  storeColor           String?           @default("#10b981")
  companyName          String?
  taxId                String?
  phone                String?           @unique
  businessDescription  String?
  businessCategory     String?
  businessAddress      String?
  lat                  Float?
  lng                  Float?
  balance              Float             @default(0)
  accountId            String?           @unique
  isForcedVerified     Boolean           @default(false)
  pushSubscriptions    Json?
  watchedListings      String            @default("[]")
  licenseUrl           String?
  savedAddresses       Address[]
  sentMessages         ChatMessage[]     @relation("MessageSender")
  favorites            Favorite[]
  createdGoals         FundingGoal[]     @relation("CreatedGoals")
  linkedCards          LinkedCard[]      @relation("UserLinkedCards")
  loanApplications     LoanApplication[]
  marketplaces         Marketplace[]     @relation("OwnedMarketplaces")
  offers               Offer[]
  orders               Order[]
  kyc                  PartnerKYC?
  paymentOrders        PaymentOrder[]
  returnRequests       ReturnRequest[]
  reviews              Review[]
  serviceLeads         ServiceLead[]     @relation("PartnerLeads")
  sentLeads            ServiceLead[]     @relation("UserLeads")
  subscriptions        Subscription[]    @relation("UserSubscriptions")
  tickets              Ticket[]
  ticketMessages       TicketMessage[]
  receivedTransactions Transaction[]     @relation("ReceivedTransactions")
  sentTransactions     Transaction[]     @relation("SentTransactions")
  cars                 UserCar[]
  chats                ChatRoom[]        @relation("ChatParticipants")
}

model UserCar {
  id          String   @id @default(uuid())
  userId      String
  brand       String
  model       String
  year        Int?
  vin         String?
  bodyType    String?
  plateNumber String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Marketplace {
  id                  String            @id @default(uuid())
  name                String
  description         String
  region              String
  category            String
  lat                 Float?
  lng                 Float?
  rating              Float             @default(0)
  views               Int               @default(0)
  users               String            @default("0")
  image               String
  images              String            @default("[]")
  price               Float             @default(4999000)
  discount            Float             @default(0)
  installmentsEnabled Boolean           @default(true)
  installmentPlans    String            @default("3,6,12")
  stock               Int               @default(0)
  isAvailable         Boolean           @default(true)
  isFeatured          Boolean           @default(false)
  featuredUntil       DateTime?
  status              String            @default("PENDING")
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  ownerId             String?
  specs               Json?
  attributes          Json?
  description_uz      String?
  name_uz             String?
  isOfficial          Boolean           @default(false)
  isVerified          Boolean           @default(false)
  partNumber          String?
  slug                String?           @unique
  videoUrl            String?
  vin                 String?
  certificates        Json?
  panoramaUrl         String?
  favorites           Favorite[]
  loanApplications    LoanApplication[]
  owner               User?             @relation("OwnedMarketplaces", fields: [ownerId], references: [id])
  offers              Offer[]
  orderItems          OrderItem[]
  priceHistory        PriceHistory[]
  reviews             Review[]
  serviceLeads        ServiceLead[]     @relation("MarketplaceLeads")

  @@index([category])
  @@index([region])
  @@index([status])
  @@index([ownerId])
  @@index([category, region, status])
  @@index([price])
  @@index([rating])
  @@index([createdAt])
}

model PriceHistory {
  id            String      @id @default(uuid())
  marketplaceId String
  price         Float
  createdAt     DateTime    @default(now())
  marketplace   Marketplace @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)

  @@index([marketplaceId])
  @@index([createdAt])
}

model Favorite {
  id            String      @id @default(uuid())
  userId        String
  marketplaceId String
  createdAt     DateTime    @default(now())
  marketplace   Marketplace @relation(fields: [marketplaceId], references: [id])
  user          User        @relation(fields: [userId], references: [id])

  @@unique([userId, marketplaceId])
}

model Order {
  id               String      @id @default(uuid())
  userId           String
  contactName      String?
  contactPhone     String?
  contactEmail     String?
  shippingAddress  String?
  shippingCity     String?
  shippingLocation String?
  shippingMethod   String?
  shippingCost     Float       @default(0)
  total            Float
  subtotal         Float       @default(0)
  commission       Float       @default(0)
  status           String      @default("CREATED")
  paymentMethod    String      @default("FULL")
  paymentProvider  String?
  installmentPlan  String?
  paymentDetails   String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  escrowAmount     Float       @default(0)
  sellerId         String?
  user             User        @relation(fields: [userId], references: [id])
  items            OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([userId, status])
}

model OrderItem {
  id             String          @id @default(uuid())
  orderId        String
  marketplaceId  String
  price          Float
  quantity       Int             @default(1)
  total          Float           @default(0)
  status         String          @default("CREATED")
  marketplace    Marketplace     @relation(fields: [marketplaceId], references: [id])
  order          Order           @relation(fields: [orderId], references: [id])
  returnRequests ReturnRequest[]
}

model Review {
  id            String      @id @default(uuid())
  rating        Int
  comment       String?
  photos        String      @default("[]")
  isVerified    Boolean     @default(false)
  userId        String
  marketplaceId String
  createdAt     DateTime    @default(now())
  marketplace   Marketplace @relation(fields: [marketplaceId], references: [id])
  user          User        @relation(fields: [userId], references: [id])
}

model Address {
  id        String   @id @default(uuid())
  name      String
  fullName  String
  phone     String
  city      String
  street    String
  details   String?
  location  String?
  isDefault Boolean  @default(false)
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Offer {
  id            String      @id @default(uuid())
  amount        Float
  status        String      @default("PENDING")
  counterAmount Float?
  userId        String
  marketplaceId String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  marketplace   Marketplace @relation(fields: [marketplaceId], references: [id])
  user          User        @relation(fields: [userId], references: [id])
}

model Category {
  id            String @id @default(uuid())
  name          String @unique
  subcategories String @default("[]")
}

model Region {
  id   String @id @default(uuid())
  name String @unique
}

model SystemSetting {
  key   String @id
  value String
}

model Transaction {
  id          String   @id @default(uuid())
  amount      Float
  type        String
  status      String   @default("PENDING")
  description String?
  metadata    String?
  senderId    String?
  receiverId  String?
  createdAt   DateTime @default(now())
  receiver    User?    @relation("ReceivedTransactions", fields: [receiverId], references: [id])
  sender      User?    @relation("SentTransactions", fields: [senderId], references: [id])
}

model JobPosting {
  id           String   @id @default(uuid())
  title        String
  department   String
  type         String
  location     String
  description  String
  requirements String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BlogPost {
  id          String    @id @default(uuid())
  title       String
  excerpt     String
  content     String
  author      String    @default("AURA Team")
  publishedAt DateTime?
  isPublished Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Ticket {
  id        String          @id @default(uuid())
  subject   String
  status    String          @default("OPEN")
  priority  String          @default("NORMAL")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  userId    String
  user      User            @relation(fields: [userId], references: [id])
  messages  TicketMessage[]
}

model TicketMessage {
  id        String   @id @default(uuid())
  message   String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  ticketId  String
  userId    String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model PartnerKYC {
  id            String   @id @default(uuid())
  userId        String   @unique
  status        String   @default("PENDING")
  licenseNumber String?
  licenseUrl    String?
  passportUrl   String?
  adminComment  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id])
}

model VerificationCode {
  id        String   @id @default(uuid())
  phone     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
}

model DistributionCenter {
  id        String   @id @default(uuid())
  name      String
  address   String
  lat       Float
  lng       Float
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Newsletter {
  id             String   @id @default(uuid())
  subject        String
  message        String
  targetRole     String
  recipientCount Int
  status         String   @default("SENT")
  createdAt      DateTime @default(now())
}

model ReturnRequest {
  id           String    @id @default(uuid())
  orderItemId  String
  userId       String
  reason       String
  details      String?
  images       String    @default("[]")
  status       String    @default("PENDING")
  refundAmount Float?
  adminComment String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  orderItem    OrderItem @relation(fields: [orderItemId], references: [id])
  user         User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

model ChatRoom {
  id            String        @id @default(uuid())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  lastMessage   String?
  lastMessageAt DateTime?
  messages      ChatMessage[]
  participants  User[]        @relation("ChatParticipants")
}

model ChatMessage {
  id         String   @id @default(uuid())
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
  senderId   String
  chatRoomId String
  chatRoom   ChatRoom @relation(fields: [chatRoomId], references: [id])
  sender     User     @relation("MessageSender", fields: [senderId], references: [id])

  @@index([chatRoomId])
  @@index([createdAt])
}

model StaticPage {
  id        String   @id @default(uuid())
  slug      String   @unique
  title     String
  content   String
  updatedAt DateTime @updatedAt
}

model LoanApplication {
  id             String       @id @default(uuid())
  userId         String
  marketplaceId  String?
  type           String
  amount         Float
  downPayment    Float
  term           Int
  monthlyPayment Float?
  status         String       @default("PENDING")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  marketplace    Marketplace? @relation(fields: [marketplaceId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

model PaymentOrder {
  id         String   @id @default(cuid())
  userId     String
  amount     Float
  provider   String
  status     String   @default("PENDING")
  externalId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

model OTP {
  id        String   @id @default(uuid())
  phone     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model ServiceLead {
  id            String      @id @default(uuid())
  name          String
  phone         String
  message       String?
  preferredDate DateTime?
  status        String      @default("PENDING")
  userId        String?
  marketplaceId String
  partnerId     String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  marketplace   Marketplace @relation("MarketplaceLeads", fields: [marketplaceId], references: [id])
  partner       User        @relation("PartnerLeads", fields: [partnerId], references: [id])
  user          User?       @relation("UserLeads", fields: [userId], references: [id])

  @@index([partnerId])
  @@index([status])
}

model FundingGoal {
  id            String   @id @default(uuid())
  title         String
  targetAmount  Float
  currentAmount Float    @default(0)
  creatorId     String
  contributors  String   @default("[]")
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  creator       User     @relation("CreatedGoals", fields: [creatorId], references: [id])

  @@index([creatorId])
}

model Subscription {
  id              String   @id @default(uuid())
  title           String
  description     String?
  amount          Float
  frequency       String   @default("MONTHLY")
  nextPaymentDate DateTime
  active          Boolean  @default(true)
  userId          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation("UserSubscriptions", fields: [userId], references: [id])

  @@index([userId])
}

model LinkedCard {
  id         String   @id @default(uuid())
  userId     String
  cardNumber String
  expiry     String
  cardHolder String?
  cardType   String
  token      String   @unique
  isActive   Boolean  @default(true)
  isDefault  Boolean  @default(false)
  balance    Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation("UserLinkedCards", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Banner {
  id        String   @id @default(uuid())
  title     String?
  imageUrl  String
  link      String?  @default("/marketplaces")
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([order])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  type      String   @default("INFO")
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId])
}
